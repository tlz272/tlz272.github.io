.DS_Store
Thumbs.db
*.log

# Audio source masters — kept locally for backup, never pushed
# (the website plays the 320 kbps MP3s in /audio/ which ARE pushed).
audio/*.wav
audio/*.aif
audio/*.aiff
audio/*.flac

# Film masters — ProRes/raw MOVs are way too big for git; only push the
# compressed web MP4s in /films/ that the dual player references.
films/*.mov
films/*.wav
films/*.aif
films/*.aiff
films/*.prores

# Film MP4s — currently kept locally only because Film Poetry is hidden and
# right-screen MP4 exceeds GitHub's 100MB per-file limit. Remove this line
# (and the MP4s must be under 100MB each) when Film Poetry is re-activated.
films/*.mp4
